{
  "name": "@ctxd/client",
  "version": "0.4.0",
  "description": "Official TypeScript/JavaScript SDK for the ctxd context substrate daemon.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/keeprlabs/ctxd",
    "directory": "clients/typescript/ctxd-client"
  },
  "homepage": "https://github.com/keeprlabs/ctxd/tree/main/clients/typescript/ctxd-client",
  "bugs": {
    "url": "https://github.com/keeprlabs/ctxd/issues"
  },
  "keywords": [
    "ctxd",
    "cloudevents",
    "msgpack",
    "context",
    "agent",
    "mcp"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.browser.js",
      "node": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0-beta2",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
